{
  "name": "kiosk",
  "version": "1.0.10",
  "private": true,
  "description": "Queue 2026 Kiosk (Electron + ESC/POS thermal printer)",
  "author": "Queue 2026",
  "main": "main.js",
  "scripts": {
    "start": "set \"ELECTRON_RUN_AS_NODE=\" & electron .",
    "dev": "set \"ELECTRON_RUN_AS_NODE=\" & set \"NODE_ENV=development\" & electron .",
    "bundle-server": "node scripts/bundle-server.js",
    "bundle-printer-worker": "node scripts/bundle-printer-worker.js",
    "prebuild": "npm version patch --no-git-tag-version",
    "build": "npm run bundle-server && npm run bundle-printer-worker && set \"CSC_IDENTITY_AUTO_DISCOVERY=false\" & set \"WIN_CSC_LINK=\" & electron-builder --win",
    "postbuild": "node scripts/clean-old-builds.js",
    "build:dir": "npm run bundle-server && npm run bundle-printer-worker && set \"CSC_IDENTITY_AUTO_DISCOVERY=false\" & electron-builder --win --dir"
  },
  "dependencies": {
    "node-thermal-printer": "^4.4.4",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.queue2026.kiosk",
    "productName": "Queue2026Kiosk",
    "electronVersion": "31.7.7",
    "npmRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Queue2026Kiosk"
    },
    "files": [
      "**/*",
      "!make-icon.ps1",
      "!dist${/*}",
      "!server-bundle${/*}",
      "!printer-worker-bundle${/*}"
    ],
    "extraResources": [
      {
        "from": "server-bundle",
        "to": "server-bundle",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "printer-worker-bundle",
        "to": "printer-worker-bundle",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
